# ── Прокси ──
TTS_BACKEND=fish                # fish, elevenlabs или voicebox
PROXY_PORT=8000                 # порт прокси
LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR
DOCS_ENABLED=false              # true — включить Swagger UI на /docs

# ── Fish Audio ──
FISH_AUDIO_API_KEY=your_fish_audio_api_key
FISH_AUDIO_BASE_URL=https://api.fish.audio
FISH_DEFAULT_MODEL=s2-pro
# ID вашего голоса из fish.audio/m/{ID}
FISH_DEFAULT_VOICE=

# ── ElevenLabs ──
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ID вашего голоса из ElevenLabs → Voices → Voice ID
ELEVENLABS_DEFAULT_VOICE=21m00Tcm4TlvDq8ikWAM

# ── VoiceBox (локальный) ──
# Для Docker: http://host.docker.internal:17493
VOICEBOX_BASE_URL=http://127.0.0.1:17493
# profile_id из GET /profiles
VOICEBOX_DEFAULT_VOICE=
VOICEBOX_LANGUAGE=ru
# Engine: qwen, luxtts, chatterbox, chatterbox_turbo
VOICEBOX_ENGINE=qwen
VOICEBOX_MODEL_SIZE=1.7B
